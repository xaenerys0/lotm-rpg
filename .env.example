# Copy to .env.local (gitignored) and fill in values.
#
# Local development (recommended): run `supabase start`, then copy the
# Project URL + Publishable key from `supabase status` into the vars below.
# Example local values:
#   NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
#
# Production / preview: use the URL + publishable (anon) key from the
# Supabase dashboard for the hosted project.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Resend (transactional email). Auth emails are sent via Supabase Auth's SMTP
# integration with Resend, configured in the Supabase DASHBOARD (not config.toml —
# Auth config is ignored on production deploys, and custom templates/SMTP break
# free-tier branching previews; see supabase/config.toml). These vars are only
# needed if/when we send mail directly via the Resend SDK.
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL="LOTM RPG <noreply@send.yourdomain.com>"

# RAG embedding (issue #60). Three transports, all speaking Ollama's /api/embed;
# the corpus (CI) and the queries (gameplay) MUST use the same approved model so
# their vectors stay comparable. Players running their own Ollama embed
# browser-direct and need none of these.
#
# Hosted Ollama Cloud (recommended). One operator-held ollama.com key gives EVERY
# signed-in player RAG retrieval regardless of their chat provider, and the same
# key drives the rag-ingest CI workflow. The browser flag turns the path on; the
# key lives ONLY server-side (the /api/proxy/ollama-cloud/api/embed route injects
# it — never NEXT_PUBLIC_). The operator pays per query.
NEXT_PUBLIC_OLLAMA_CLOUD_EMBEDDING=1
# OLLAMA_CLOUD_API_KEY=     # server-only; also the rag-ingest CI secret

# Self-hosted operator box (alternative to Ollama Cloud). An always-on CPU box
# hosting the approved models behind /api/embed. Browser-reachable (query
# embedding is browser-direct) and CANNOT be a Vercel serverless function (no
# resident model). Leave unset when using Ollama Cloud above.
# NEXT_PUBLIC_OPERATOR_EMBEDDING_URL=https://embed.yourdomain.com

# Operator-side ONLY (pnpm rag:load) — never ship to the browser or commit real values.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
