# Copy to .env.local (gitignored) and fill in values.
#
# Local development (recommended): run `supabase start`, then copy the
# Project URL + Publishable key from `supabase status` into the vars below.
# Example local values:
#   NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
#
# Production / preview: use the URL + publishable (anon) key from the
# Supabase dashboard for the hosted project.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Resend (transactional email). Auth emails are sent via Supabase Auth's SMTP
# integration with Resend, configured in the Supabase DASHBOARD (not config.toml —
# Auth config is ignored on production deploys, and custom templates/SMTP break
# free-tier branching previews; see supabase/config.toml). These vars are only
# needed if/when we send mail directly via the Resend SDK.
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL="LOTM RPG <noreply@send.yourdomain.com>"

# RAG embedding (issue #60). The corpus (CI) and the queries (gameplay) MUST use
# the same approved model so their vectors stay comparable. Players running their
# own Ollama embed browser-direct and need none of these.
#
# Hosted Cloudflare Workers AI (recommended). Cloudflare runs the open bge-m3
# model (one of our approved 1024-dim models) on its free tier (10k Neurons/day);
# one operator-held token gives EVERY signed-in player RAG retrieval regardless of
# their chat provider, and the same token drives the rag-ingest CI workflow. The
# browser flag turns the path on; the token lives ONLY server-side (the
# /api/proxy/cloudflare/embed route injects it — never NEXT_PUBLIC_). Cloudflare
# does not train on inputs.
NEXT_PUBLIC_CLOUDFLARE_EMBEDDING=1
# CF_ACCOUNT_ID=           # server-only; also a rag-ingest CI secret
# CF_API_TOKEN=            # server-only (Workers AI scope); also a rag-ingest CI secret
#
# Per-user rate limit for the operator-funded embed proxy (server-only). Bounds
# how often any one signed-in player can spend your quota. Defaults: 30 / 60s.
# Set EMBED_RATE_LIMIT_MAX=0 to disable the limit entirely.
# EMBED_RATE_LIMIT_MAX=30
# EMBED_RATE_LIMIT_WINDOW_SECONDS=60

# Self-hosted operator box (alternative to Cloudflare). An always-on CPU box
# hosting the approved models behind Ollama's /api/embed. Browser-reachable (query
# embedding is browser-direct) and CANNOT be a Vercel serverless function (no
# resident model). Leave unset when using Cloudflare above.
# NEXT_PUBLIC_OPERATOR_EMBEDDING_URL=https://embed.yourdomain.com

# Operator-side ONLY (pnpm rag:load) — never ship to the browser or commit real values.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
