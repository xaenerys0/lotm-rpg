# Copy to .env.local (gitignored) and fill in values.
#
# Local development (recommended): run `supabase start`, then copy the
# Project URL + Publishable key from `supabase status` into the vars below.
# Example local values:
#   NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
#
# Production / preview: use the URL + publishable (anon) key from the
# Supabase dashboard for the hosted project.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Resend (transactional email). Supabase Auth's SMTP integration uses Resend,
# configured in `supabase/config.toml` ([auth.email.smtp], pass = env(RESEND_API_KEY))
# so branching preview environments inherit it. RESEND_API_KEY must be set as a
# Supabase project secret for the branch/config pipeline; it is also used if/when
# we send mail directly via the Resend SDK.
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL="LOTM RPG <noreply@send.yourdomain.com>"

# RAG embedding (issue #60). The operator's always-on CPU box that hosts the
# approved embedding models behind an Ollama-compatible /api/embed route -- the
# zero-setup default/fallback for players whose chat provider isn't Ollama. It
# is browser-reachable (query embedding is browser-direct) and CANNOT be a
# Vercel serverless function (no resident model). Players running their own
# Ollama embed browser-direct instead and don't need this.
NEXT_PUBLIC_OPERATOR_EMBEDDING_URL=https://embed.yourdomain.com

# Operator-side ONLY (pnpm rag:load) — never ship to the browser or commit real values.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
